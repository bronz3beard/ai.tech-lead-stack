generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password_hash String?
  role          Role      @default(DEVELOPER)
  firstName     String?
  lastName      String?
  preferredModel String?  @default("gemini")
  claudeApiKey  String?   @map("claudApiKey")
  openaiApiKey  String?
  geminiApiKey  String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  chats         Chat[]
  projects      Project[]
  sessions      Session[]
  analyticsEvents AnalyticsEvent[]
}

model AnalyticsEvent {
  id               String   @id @default(cuid())
  skillName        String?
  userId           String
  model            String?
  agent            String?
  duration         Float?
  status           String?
  error            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  totalCost        Float?
  langfuseTraceId  String?
  metadata         Json?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([skillName, createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  repoUrl        String?
  githubFullName String?  @unique
  ownerId        String?
  createdAt      DateTime @default(now())
  chats          Chat[]
  owner          User?    @relation(fields: [ownerId], references: [id])
  accessGrants   ProjectAccess[]
}

model ProjectAccess {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      Role
  createdAt DateTime @default(now())

  @@unique([projectId, role])
}

model Chat {
  id        String    @id @default(cuid())
  title     String    @default("New Chat")
  userId    String
  projectId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

enum Role {
  DESIGNER
  QA
  PM
  DEVELOPER
  ADMIN
}

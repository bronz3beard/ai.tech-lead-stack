{
  "name": "@bronz3beard/tech-lead-stack",
  "version": "1.0.0",
  "description": "RTK-powered agent skills for Tech Leads.",
  "bin": {
    "lead-init": "./install.sh",
    "lead-run": "./scripts/rtk-run.sh",
    "tech-lead-clean": "./scripts/cleanup.sh"
  },
  "rtk": {
    "tools": {
      "accessibility-auditor": "cat .ai/skills/accessibility-auditor.md",
      "changelog-generator": "cat .ai/skills/changelog-generator.md",
      "clean-code": "cat .ai/skills/clean-code.md",
      "cleanup": "bash scripts/cleanup.sh",
      "code-review-checklist": "cat .ai/skills/code-review-checklist.md",
      "codebase-onboarding-intelligence": "cat .ai/skills/codebase-onboarding-intelligence.md",
      "create-pr": "bash scripts/gh-pr-create.sh",
      "daily-standup": "cat .ai/skills/daily-standup.md",
      "eval": "node scripts/autoeval-check.mjs",
      "feature-design-assistant": "cat .ai/skills/feature-design-assistant.md",
      "mission-architect": "cat .ai/skills/mission-architect.md",
      "planning-expert": "cat .ai/skills/planning-expert.md",
      "pr-automator": "cat .ai/skills/pr-automator.md",
      "product-strategist": "cat .ai/skills/product-strategist.md",
      "regression-bug-fix": "cat .ai/skills/regression-bug-fix.md",
      "security-audit": "cat .ai/skills/security-audit.md",
      "style-logic-exporter": "cat .ai/skills/style-logic-exporter.md",
      "technical-debt-auditor": "cat .ai/skills/technical-debt-auditor.md",
      "validate-scripts": "bash scripts/validate-scripts.sh",
      "validate-skills": "bash scripts/validate-skills.sh",
      "visual-verifier": "node scripts/visual-verifier.mjs"
    }
  },
  "scripts": {
    "test": "jest",
    "setup-browsers": "npx playwright install chromium",
    "postinstall": "prisma generate && npm run setup-browsers",
    "format": "npx prettier --write \".ai/skills/*.md\" \"scripts/*.{js,mjs}\" \"README.md\"",
    "format:check": "npx prettier --check \".ai/skills/*.md\" \"scripts/*.{js,mjs}\" \"README.md\"",
    "lint": "npx markdownlint-cli \".ai/skills/*.md\"",
    "lint:fix": "npx markdownlint-cli --fix \".ai/skills/*.md\" && npm run format",
    "validate:skills": "bash scripts/validate-skills.sh",
    "validate:scripts": "bash scripts/validate-scripts.sh",
    "prepare": "husky",
    "mcp:start": "npx tsx src/mcp-server/index.ts",
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint:next": "next lint"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/google": "^3.0.61",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.159",
    "@base-ui/react": "^1.3.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.20.0",
    "ai": "^6.0.157",
    "autoevals": "latest",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "easymde": "^2.20.0",
    "gray-matter": "^4.0.3",
    "langfuse-core": "^3.38.20",
    "langfuse-node": "^3.38.20",
    "lucide-react": "^0.477.0",
    "next": "^16.2.3",
    "next-auth": "^4.24.13",
    "octokit": "^5.0.5",
    "p-map": "^7.0.4",
    "pg": "^8.20.0",
    "playwright": "latest",
    "playwright-extra": "latest",
    "postcss": "^8.5.9",
    "prisma": "^7.7.0",
    "puppeteer-extra-plugin-stealth": "latest",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-simplemde-editor": "^5.2.0",
    "rechart": "^0.0.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "langfuse": "^3.38.20",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "agent",
    "tech-lead",
    "automation",
    "rtk",
    "minimumcd"
  ],
  "author": "bronz3beard",
  "license": "MIT",
  "lint-staged": {
    ".ai/skills/*.md": [
      "bash scripts/validate-skills.sh",
      "npx markdownlint-cli --fix",
      "npx prettier --write"
    ],
    "scripts/*": [
      "bash scripts/validate-scripts.sh"
    ],
    "scripts/*.{js,mjs}": [
      "npx prettier --write"
    ]
  }
}

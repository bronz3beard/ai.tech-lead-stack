{
  "name": "@bronz3beard/tech-lead-stack",
  "version": "1.0.0",
  "description": "RTK-powered agent skills for Tech Leads.",
  "bin": {
    "lead-init": "./install.sh",
    "lead-run": "./scripts/rtk-run.sh",
    "tech-lead-clean": "./scripts/cleanup.sh"
  },
  "rtk": {
    "tools": {
      "bridge": "cat .ai/skills/strategy-to-execution.md",
      "changelog": "cat .ai/skills/changelog-generator.md",
      "clean-code": "cat .ai/skills/clean-code.md",
      "cleanup": "bash scripts/cleanup.sh",
      "code-review-checklist": "cat .ai/skills/code-review-checklist.md",
      "create-pr": "bash scripts/gh-pr-create.sh",
      "design": "cat .ai/skills/feature-design-assistant.md",
      "dr-remediate": "cat .ai/skills/dr-remediation.md",
      "eval": "node scripts/autoeval-check.js",
      "git-parse": "bash scripts/git-intel-parser.sh",
      "mission-control": "cat .ai/skills/mission-control.md",
      "onboarding-intel": "cat .ai/skills/codebase-onboarding-intelligence.md",
      "planning": "cat .ai/skills/planning-expert.md",
      "pr-automator": "cat .ai/skills/pr-automator.md",
      "product-strategy": "cat .ai/skills/product-strategist.md",
      "qa-remediate": "cat .ai/skills/qa-remediation.md",
      "quality-gatekeeper": "cat .ai/skills/quality-gatekeeper.md",
      "security-scan": "cat .ai/skills/security-audit.md",
      "standup": "cat .ai/skills/daily-standup.md",
      "technical-debt-auditor": "cat .ai/skills/technical-debt-auditor.md",
      "upload": "python3 scripts/upload-evidence.py",
      "visual-verifier": "cat .ai/skills/visual-verifier.md"
    }
  },
  "scripts": {
    "test": "echo \"No tests specified.\" && exit 0",
    "setup-browsers": "npx playwright install chromium",
    "postinstall": "npm run setup-browsers",
    "format": "npx prettier --write \".ai/skills/*.md\" \"scripts/*.js\" \"README.md\"",
    "format:check": "npx prettier --check \".ai/skills/*.md\" \"scripts/*.js\" \"README.md\"",
    "lint": "npx markdownlint-cli \".ai/skills/*.md\"",
    "lint:fix": "npx markdownlint-cli --fix \".ai/skills/*.md\" && npm run format",
    "validate:skills": "bash scripts/validate-skills.sh",
    "validate:scripts": "bash scripts/validate-scripts.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "autoevals": "latest",
    "playwright": "latest",
    "playwright-extra": "latest",
    "puppeteer-extra-plugin-stealth": "latest",
    "dotenv": "latest"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "markdownlint-cli": "^0.40.0",
    "prettier": "^3.0.0"
  },
  "keywords": [
    "agent",
    "tech-lead",
    "automation",
    "rtk",
    "minimumcd"
  ],
  "author": "bronz3beard",
  "license": "MIT",
  "lint-staged": {
    ".ai/skills/*.md": [
      "bash scripts/validate-skills.sh",
      "npx markdownlint-cli --fix",
      "npx prettier --write"
    ],
    "scripts/*": [
      "bash scripts/validate-scripts.sh"
    ],
    "scripts/*.js": [
      "npx prettier --write"
    ]
  }
}
